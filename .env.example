# Resido Render production environment variables
# Copy these KEYS into Render > Resido Web Service > Environment.
# Do not commit real passwords, API keys, database URLs, or secrets.

NODE_ENV=production
AUTH_SECRET=
FRONTEND_ORIGIN=https://residoco.com
PUBLIC_APP_URL=https://residoco.com

# Render PostgreSQL. Paste the Render Internal Database URL here.
DATABASE_URL=

# First/live super admin account
SUPER_ADMIN_EMAIL=your-real-email@example.com
SUPER_ADMIN_PASSWORD=change-this-to-a-strong-production-password
SUPER_ADMIN_NAME=Your Name
SUPER_ADMIN_PHONE=

# HTTPS email sending through Resend. This replaces Gmail/SMTP and works on Render Free.
# In Resend, create an API key, then set MAIL_FROM to a verified sender/domain.
# For initial testing only, you may use: MAIL_FROM="Resido" <onboarding@resend.dev>
# For production after verifying residoco.com in Resend, use for example: MAIL_FROM="Resido" <support@residoco.com>
RESEND_API_KEY=
MAIL_FROM="Resido" <onboarding@resend.dev>
MAIL_REPLY_TO=your-real-email@example.com
SUPPORT_EMAIL=your-real-email@example.com
# Optional; normally leave empty
# RESEND_API_URL=https://api.resend.com/emails
# EMAIL_API_TIMEOUT_MS=15000

# Stripe real payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REQUIRE_CONNECT=false
PASS_CARD_FEES_TO_RESIDENT=true
CARD_PROCESSING_PERCENT=1.5
CARD_PROCESSING_FIXED_CENTS=26
ALLOW_DEMO_CARD_PAYMENTS=false

# Optional safety limits
RATE_LIMIT_GENERAL_PER_MINUTE=240
RATE_LIMIT_AUTH_PER_15_MINUTES=8
RATE_LIMIT_PASSWORD_RESET_PER_HOUR=5
RESET_TOKEN_MAX_ATTEMPTS=5
RATE_LIMIT_PAYMENTS_PER_MINUTE=10
RATE_LIMIT_WRITES_PER_MINUTE=60

# Optional backup/export behavior
EXPORT_INCLUDE_FILE_DATA=false
